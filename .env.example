# Temporarily bypass browser sign-in. Keep false or unset for protected access.
RECOMP_PUBLIC_ACCESS=false

# Google browser access (recommended). Create a Web OAuth client and use:
# https://your-domain.example/api/auth/callback/google
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret

# Auth.js session encryption. Create independently with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-64-character-random-value

# Password browser access (optional fallback; separate from the agent API key)
RECOMP_PASSWORD=replace-with-a-long-random-value

# Used to sign fallback password sessions. Create independently with:
# openssl rand -hex 32
RECOMP_SESSION_SECRET=replace-with-a-different-64-character-random-value

# Server-to-server agent access. Create with: openssl rand -hex 32
# Keep this only in .env.local or your host's encrypted environment settings.
RECOMP_API_KEY=replace-with-a-64-character-random-value
