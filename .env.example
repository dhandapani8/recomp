# Browser access (optional; this is separate from the agent API key)
RECOMP_PASSWORD=replace-with-a-long-random-value

# Used to sign browser admin sessions. Create independently with:
# openssl rand -hex 32
RECOMP_SESSION_SECRET=replace-with-a-different-64-character-random-value

# Server-to-server agent access. Create with: openssl rand -hex 32
# Keep this only in .env.local or your host's encrypted environment settings.
RECOMP_API_KEY=replace-with-a-64-character-random-value
